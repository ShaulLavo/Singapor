{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "sortPackageJson": true,
  "sortTailwindcss": true,
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    ".turbo",
    ".vite",
    "bun.lock",
    "*.tsbuildinfo",
    "*.patch",
    "references/**"
  ]
}
