{
  "name": "@editor/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./src/style.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./debug": "./src/debug.ts",
    "./document": "./src/public/document.ts",
    "./editor": "./src/editor.ts",
    "./extensions": "./src/public/extensions.ts",
    "./internal": "./src/internal.ts",
    "./logging": "./src/logging/index.ts",
    "./logging/evlog": "./src/logging/evlog.ts",
    "./rendering": "./src/public/rendering.ts",
    "./secondary-views": "./src/public/secondaryViews.ts",
    "./shiki": "./src/shiki/index.ts",
    "./syntax": "./src/public/syntax.ts",
    "./testing": "./src/public/testing.ts",
    "./style.css": "./src/style.css"
  },
  "scripts": {
    "bench:anchors": "bun bench/pieceTable-anchors.ts",
    "bench:transforms": "bun bench/displayTransforms.ts",
    "bench:fold-map": "bun bench/foldMap.ts",
    "bench:piece-table": "bun bench/pieceTable-insertions.ts",
    "bench:virtualization": "bun bench/virtualization.ts",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@tanstack/hotkeys": "0.8.0",
    "diff": "^8.0.3",
    "evlog": "^2.17.0",
    "shiki": "^1.29.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@typescript/native-preview": "7.0.0-dev.20260524.1",
    "@vitest/browser": "^3.2.4",
    "happy-dom": "^20.8.9",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "typescript": "~5.9.3",
    "vitest": "^3.1.1"
  }
}
