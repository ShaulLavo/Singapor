    "happy-dom": "^20.8.9",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "typescript": "~5.9.3",
    "vitest": "^3.1.1"
  },
  "peerDependencies": {
    "@editor/core": "workspace:*"
  }
