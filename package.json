{
	"name": "editor-workspace",
	"private": true,
	"packageManager": "bun@1.3.10",
	"workspaces": [
		"packages/*",
		"examples/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"typecheck": "turbo typecheck",
		"lint": "turbo lint",
		"format": "turbo format",
