		"health": "bun scripts/architecture-health.mjs",
		"health:write": "bun scripts/architecture-health.mjs --write",
		"test": "turbo test"
	},
	"devDependencies": {
		"turbo": "^2.9.2"
	},
	"dependencies": {
		"better-result": "^2.7.0"
	}
}
